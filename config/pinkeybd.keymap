#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 80

&lt {
    tapping-term-ms = <200>;
    flavor = "tap-unless-interrupted";
};

/ {
    behaviors {
        rot_kp: sensor_rotate_kp {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&kp>, <&kp>;

            tap-ms = <1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        /       |       ,       |       .       |      -        |      ;       |    ESC         |                   |           |       L      |       R       |       D       |       Y       |      P      |
        // |        A       |       O       |       E       |      I        |      U       |    SCROLLLOCK  |                   |           |       G      |       N       |       T       |       S       |      K      |
        // |        X       |       C       |       V       |      W        |      Q       |    TAB         |                   |     F     |       J      |       H       |       M       |       B       |      Z      |
        // |    L_SHIFT     |               |               |   LOWER / Jp  |    Space     |    LEFT_WIN    |                   |  R_SHIFT  |      ENTER   |  LOWER2 / Ja  |               |               |   FUN_L     |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        default_layer {
            bindings = <
&kp Q       &kp W        &kp E        &kp R        &kp T          &kp ESC         &kp Y      &kp U          &kp I              &kp O       &kp P
&kp A       &kp S        &kp D        &kp F        &kp G          &kp SCROLLLOCK  &kp H      &kp J          &kp K              &kp L       &kp ENTER
&kp Z       &kp X        &kp C        &kp V        &kp B          &mkp LCLK       &kp N      &kp M          &kp COMMA          &kp PERIOD  &kp SLASH
&kp LSHIFT  &lt 1 LANG1  &lt 2 SPACE  &lt 3 LANG2  &kp BACKSPACE  &mkp RCLK       &kp SPACE  &kp BACKSPACE  &kp RIGHT_CONTROL
            >;

            sensor-bindings = <&rot_kp PAGE_DOWN PAGE_UP>;
        };

        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,       |       END     |     （        |      ”        |    PAUSE_BREAK|                  |            |      （       |       ）     |        ↑      |        [      |      ]      |
        // |    HOME        |       C_SAVE  |       END     |       ）      |       U       |    SCROLLLOCK |                  |            |   Backspace   |       ←      |        ↓      |        →      |     DEL     |
        // |    UNDO        |       CUT     |       COPY    |       PASTE   |       Q       |    TAB        |                  |   PSCRN    |    ' / "      |    = / +     |    \ / |      |    ` / ~      |    INS      |
        // |    L_SHIFT     |               |               |       none    |    SPACE      |    LALT       |                  |   RSHIFT   |   ENTER       |       FUN_L  |               |               |    RCTRL    |
        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Lower_layer {
            bindings = <
&kp PLUS       &kp N7            &kp NUMBER_8      &kp NUMBER_9      &kp LS(AMPERSAND)  &kp PAUSE_BREAK  &kp LPAR   &kp RPAR   &kp UP     &kp LBKT           &kp RBKT
&kp NUMBER_0   &kp LS(NUMBER_4)  &kp NUMBER_5      &kp NUMBER_6      &kp PERCENT        &kp SCROLLLOCK   &kp BSPC   &kp LEFT   &kp DOWN   &kp RIGHT          &kp DEL
&kp LC(EQUAL)  &kp LC(NUMBER_1)  &kp LC(NUMBER_2)  &kp LC(NUMBER_3)  &kp DOLLAR         &kp TAB          &kp APOS   &kp EQUAL  &kp BSLH   &kp DOUBLE_QUOTES  &kp INS
&kp LSHIFT     &none             &kp SPACE         &to 0             &kp PSCRN          &kp RSHIFT       &kp ENTER  &mo 4      &kp RCTRL
            >;
        };

        // -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,        |       END     |       {       |       ’      |    ESC        |                  |            |      L      |      R         |    PG_UP      |     {       |      }      |
        // |    HOME        |       C_SAVE   |       END     |       }       |       U      |    LCTRL      |                  |            |  Backspace  |    HOME        |    PG_DN      |    END      |    DEL      |
        // |    UNDO        |       CUT      |       COPY    |       PASTE   |       Q      |    TAB        |                  |      F     |    ' / "    |    = / +       |    \ / |      |    ` / ~    |    INS      |
        // |    L_SHIFT     |                |               |       BT_L    |      SPACE   |    LALT       |                  |   ENTER    |    none     |   R_SHIFT      |               |             |   R_SHIFT   |
        // -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Lower2_layer {
            bindings = <
&none       &kp COMMA  &kp END    &kp LEFT_BRACE   &kp SINGLE_QUOTE  &kp ESC     &mkp LCLK  &mkp RCLK  &kp PG_UP   &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS
&kp HOME    &kp LS(S)  &kp END    &kp RIGHT_BRACE  &kp U             &kp SLCK    &mkp MCLK  &kp HOME   &kp PG_DN   &kp END               &kp SEMICOLON
&kp LC(Z)   &kp LC(X)  &kp LC(C)  &kp LC(V)        &mkp LCLK         &mkp RCLK   &kp APOS   &kp EQUAL  &kp BSLH    &kp GRAVE             &kp INS
&kp LSHIFT  &mo 5      &to 3      &to 0            &kp PSCRN         &kp RSHIFT  &kp ENTER  &none      &kp RSHIFT
            >;

            sensor-bindings = <&rot_kp PAGE_DOWN PAGE_UP>;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        1       |      2        |       3       |       4       |       5       |    ESC        |               |            |      6       |      7        |       8       |       9       |       0       |
        // |        !       |      @        |       #       |       $       |       %       |    none       |               |            |      ^       |      &        |       *       |       (       |       )       | 
        // |        F1      |     F2        |     F3        |       F4      |       F5      |    TAB        |               |     F11    |    ' / "     |    = / +      |    \ / |      |    ` / ~      |       INS     |
        // |    L_SHIFT     |               |               | En / LOWER    |    Space      |    LSIHT      |               |   R_SHIFT  |      ENTER   |     none      |               |               |       R_SHIFT |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Num_layer {
            bindings = <
&kp N1      &kp N2      &kp N3      &kp N4      &kp N5      &kp ESC     &kp N6      &kp N7      &kp N8      &kp N9      &kp N0
&kp LS(N1)  &kp LS(N2)  &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &none       &kp RS(N6)  &kp RS(N7)  &kp RS(N8)  &kp RS(N9)  &kp RS(N0)
&kp F1      &kp F2      &kp F3      &kp F4      &kp F5      &kp TAB     &kp APOS    &kp EQUAL   &kp BSLH    &kp GRAVE   &kp INS
&mo LSHIFT  &mo 5       &kp SPACE   &to 0       &kp F11     &kp RSHIFT  &kp ENTER   &none       &kp RSHIFT
            >;
        };

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |     F1      |     F2     |     F3     |     F4     |    F5      |    none    |                |            |    F6      |    F7      |    F8      |    F9       |     F10     |
        // |     F11     |     F12    |     F13    |     F14    |    F15     |    none    |                |   none     |    F16     |    F17     |    F18     |    F19      |     F20     |
        // |     none    |    none    |    none    |    none    |   none     |    none    |                |   none     |    none    |    none    |    none    |    none     |     none    |
        // |     L_SHIFT |    none    |    none    |    none    |   none     |    none    |                |   none     |    none    |    none    |    none    |    none     |     R_SHIFT |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Func_layer {
            bindings = <
&kp F1      &kp F2   &kp F3   &kp F4   &kp F5   &none  &kp F6   &kp F7   &kp F8      &kp F9   &kp F10
&kp F11     &kp F12  &kp F13  &kp F14  &kp F15  &none  &kp F16  &kp F17  &kp F18     &kp F19  &kp F20
&none       &none    &none    &none    &none    &none  &none    &none    &none       &none    &none
&kp LSHIFT  &none    &none    &to 0    &none    &none  &none    &none    &kp RSHIFT
            >;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |            |    none    |    none    |    none    |   none     |    none    |
        // |  BT_SEL 0  |  BT_SEL 1  |  BT_SEL 2  |  BT_SEL 3  |   none     |    none    |                  |            |    none    |    none    |    none    |   BT_CLR   | BT_CLR_ALL |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |   BT_PRV   |    none    |   BT_NXT   |    none    |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |    none    |    none    |   none     |    none    |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Bt_layer {
            bindings = <
&bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_SEL 5  &none  &none       &none  &bt BT_CLR  &bt BT_CLR_ALL
&none         &none         &none         &none         &none         &none         &none  &bt BT_PRV  &none  &bt BT_NXT  &none
&none         &none         &none         &none         &none         &none         &none  &none       &none  &none       &none
&none         &none         &none         &to 0         &none         &none         &none  &none       &none
            >;
        };
    };
};
